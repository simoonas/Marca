#[cfg(test)]
mod integration_tests {
    use crate::db::Database;
    use crate::import::html::parse_html_bookmarks;
    use std::fs;

    #[test]
    fn test_full_html_import() {
        let html = fs::read_to_string("/home/basil/test_bookmarks.html").unwrap();
        let bookmarks = parse_html_bookmarks(&html).unwrap();
        
        let db = Database::new().unwrap();
        let result = db.import_bookmarks(bookmarks.clone()).unwrap();
        
        println!("Imported: {}", result.imported);
        println!("Skipped: {}", result.skipped);
        for err in &result.errors {
            println!("Error: {}", err);
        }
        
        // This is a bit flaky because it depends on the existing DB state,
        // but it will print the errors if any.
        let total = result.imported + result.skipped;
        assert_eq!(total, 6);
    }
}
