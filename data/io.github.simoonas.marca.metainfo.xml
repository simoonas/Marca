    <screenshot type="default">
      <image>https://raw.githubusercontent.com/simoonas/Marca/v0.1.0/assets/default.png</image>
      <caption>Main view (dark mode)</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/simoonas/Marca/v0.1.0/assets/any-tags.png</image>
      <caption>Bookmarks containing any pinned tags </caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/simoonas/Marca/v0.1.0/assets/all-tags.png</image>
      <caption>Bookmarks tagged `Eco` and `map` sorted by modified time</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/simoonas/Marca/v0.1.0/assets/edit-create.png</image>
