  <releases>
    <release version="0.1.0" date="2026-05-18">
      <url type="details">https://github.com/simoonas/Marca/releases/tag/v0.1.0</url>
      <description>
        <p>First release!</p>
          <ul>
            <li>User-friendly UI with hotkey hints, made with gtk4 and libadwaita</li>
            <li>Full Text Search</li>
            <li>Filter using tags inclusively/exclusively</li>
            <li>Sort by created, modified, title, URL, Relevance</li>
            <li>Keyboard controls</li>
            <li>Import from browsers</li>
            <li>Coming soon: P2P sync, exports, reader mode and more.</li>
          </ul>
      </description>
    </release>
  </releases>

</component>
