<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.simoonas.marca</id>
  
  <name>Marca</name>
  <summary>Organize &amp; find your deeplinks quickly</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>
  
  <description>
    <p>
      Find your web bookmarks or deeplinks to apps with tags and full-text search
    </p>

    <p>**Features:**</p>
    <ul>
      <li>Full Text Search</li>
      <li>Filter using tags inclusively/exclusively</li>
      <li>Sort by created, modified, title, URL, Relevance</li>
      <li>Keyboard controls</li>
      <li>Import from browsers</li>
      <li>More coming soon!</li>
    </ul>
  </description>
  
  <developer id="github.com/simoonas">
    <name translate="no">Simonas Ju</name>
  </developer>

  <url type="vcs-browser">https://github.com/simoonas/Marca</url>
  <url type="bugtracker">https://github.com/simoonas/Marca/issues</url>
  <url type="faq">https://github.com/simoonas/Marca#readme</url>
  <url type="homepage">https://github.com/simoonas/Marca</url> 

  <launchable type="desktop-id">io.github.simoonas.marca.desktop</launchable>
  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#8ff0a4</color>
    <color type="primary" scheme_preference="dark">#26a269</color>
  </branding>

